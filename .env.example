NEXT_PUBLIC_INSTANT_APP_ID=
# Required for sign-in: bootstrap creates/updates the InstantDB user after Google OAuth
INSTANT_APP_ID=
INSTANT_APP_ADMIN_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# NextAuth: random string you generate (openssl rand -base64 32). Alias: NEXTAUTH_SECRET
AUTH_SECRET=
# Canonical site URL for OAuth callbacks and session (use your deploy URL in production)
NEXTAUTH_URL=http://localhost:3000

OPENAI_API_KEY=
GOOGLE_BOOKS_API_KEY=
